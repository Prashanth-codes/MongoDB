Find users whose number of skills is greater than the average number of skills of all users.
db.users.aggregate([
  {
    $addFields: {
      skillsCount: { $size: "$skills" }
    }
  },
  {
    $group: {
      _id: null,
      avgSkills: { $avg: "$skillsCount" },
      users: {
        $push: {
          name: "$name",
          skillsCount: "$skillsCount"
        }
      }
    }
  },
  {
    $unwind: "$users"
  },
  {
    $match: {
      $expr: { $gt: ["$users.skillsCount", "$avgSkills"] }
    }
  },
  {
    $project: {
      _id: 0,
      name: "$users.name",
      skillsCount: "$users.skillsCount",
      // avgSkills: 1
    }
  }
])

