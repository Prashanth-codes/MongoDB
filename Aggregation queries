Find users who have the maximum number of skills in the entire collection
db.users.aggregate([
  {
    $addFields: {
      skillcnt: {$size: "$skills"}
    }
  },
  {
    $group: {
      _id: null,
      maxcnt: {$max: "$skillcnt"},
      users: {
        $push: {
          name: "$name",
          skillcnt: "$skillcnt"
        }
      }
    }
  },
  {
    $project: {
      users: {
        $filter: {
          input: "$users",
          as: "u",
          cond: {
            $eq: ["$$u.skillcnt","$maxcnt"]
          }
        }
      }
    }
  }
])

